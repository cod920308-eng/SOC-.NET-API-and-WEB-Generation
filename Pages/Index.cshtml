@page
@model KMC_Main_WEB.Pages.IndexModel
@{
    ViewData["Title"] = "Home";
}

<style>
    :root {
        --kmc-blue: #1a56db;
        --kmc-blue-dark: #1e429f;
        --kmc-blue-light: #e8f0fe;
        --kmc-accent: #0ea5e9;
    }

    /* ── HERO ── */
    .hero {
        position: relative;
        min-height: 520px;
        display: flex;
        align-items: center;
        overflow: hidden;
        background: #0c1e4a;
    }

    .hero-bg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.35;
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, rgba(14,30,74,0.92) 0%, rgba(26,86,219,0.55) 60%, transparent 100%);
    }

    .hero-content {
        position: relative;
        z-index: 2;
        padding: 4rem 0;
    }

    .hero-eyebrow {
        display: inline-block;
        background: rgba(255,255,255,0.15);
        color: rgba(255,255,255,0.9);
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        padding: 5px 14px;
        border-radius: 100px;
        margin-bottom: 1.2rem;
        border: 1px solid rgba(255,255,255,0.2);
    }

    .hero h1 {
        font-size: clamp(2rem, 4.5vw, 3.4rem);
        font-weight: 800;
        color: #fff;
        line-height: 1.15;
        margin-bottom: 1.2rem;
    }

        .hero h1 span {
            color: #7dd3fc;
        }

    .hero p {
        color: rgba(255,255,255,0.78);
        font-size: 1.05rem;
        max-width: 480px;
        line-height: 1.7;
        margin-bottom: 2rem;
    }

    .hero-btns {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .btn-hero-primary {
        background: white;
        color: var(--kmc-blue-dark);
        border: none;
        border-radius: 8px;
        padding: 12px 28px;
        font-size: 0.92rem;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.2s;
    }

        .btn-hero-primary:hover {
            background: #dbeafe;
            color: var(--kmc-blue-dark);
            transform: translateY(-1px);
        }

    .btn-hero-secondary {
        background: transparent;
        color: white;
        border: 2px solid rgba(255,255,255,0.5);
        border-radius: 8px;
        padding: 12px 28px;
        font-size: 0.92rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s;
    }

        .btn-hero-secondary:hover {
            border-color: white;
            background: rgba(255,255,255,0.1);
            color: white;
        }

    /* ── STATS STRIP ── */
    .stats-strip {
        background: var(--kmc-blue);
        padding: 1.6rem 0;
    }

    .stat-item {
        text-align: center;
        color: white;
        padding: 0 1rem;
        border-right: 1px solid rgba(255,255,255,0.2);
    }

        .stat-item:last-child {
            border-right: none;
        }

    .stat-number {
        font-size: 1.9rem;
        font-weight: 800;
        line-height: 1;
        margin-bottom: 4px;
    }

    .stat-label {
        font-size: 0.75rem;
        font-weight: 500;
        opacity: 0.75;
        letter-spacing: 0.06em;
        text-transform: uppercase;
    }

    /* ── SHARED ── */
    .section-label {
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--kmc-blue);
        margin-bottom: 8px;
    }

    .section-title {
        font-size: clamp(1.5rem, 3vw, 2.1rem);
        font-weight: 800;
        color: #0f172a;
        line-height: 1.2;
        margin-bottom: 0.8rem;
    }

    .section-sub {
        font-size: 0.95rem;
        color: #64748b;
        line-height: 1.7;
        max-width: 520px;
    }

    /* ── FEATURES ── */
    .features-section {
        padding: 5rem 0 4rem;
        background: #f8faff;
    }

    .feature-card {
        background: white;
        border-radius: 14px;
        padding: 1.75rem;
        border: 1px solid #e2e8f0;
        height: 100%;
        transition: all 0.25s;
    }

        .feature-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 32px rgba(26,86,219,0.1);
            border-color: #bfdbfe;
        }

    .feature-icon {
        width: 52px;
        height: 52px;
        background: var(--kmc-blue-light);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin-bottom: 1rem;
    }

    .feature-card h4 {
        font-size: 1.05rem;
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 0.5rem;
    }

    .feature-card p {
        font-size: 0.875rem;
        color: #64748b;
        line-height: 1.65;
        margin: 0;
    }

    /* ── PERAHERA SPOTLIGHT ── */
    .perahera-section {
        padding: 5rem 0;
        background: white;
    }

    .perahera-img-wrap {
        border-radius: 16px;
        overflow: hidden;
        position: relative;
        height: 420px;
    }

        .perahera-img-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .perahera-badge {
        position: absolute;
        bottom: 20px;
        left: 20px;
        background: rgba(14,30,74,0.9);
        color: white;
        padding: 8px 16px;
        border-radius: 8px;
        font-size: 0.82rem;
        font-weight: 600;
        backdrop-filter: blur(8px);
        border: 1px solid rgba(255,255,255,0.15);
    }

    .highlight-pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: var(--kmc-blue-light);
        color: var(--kmc-blue);
        font-size: 0.78rem;
        font-weight: 600;
        padding: 4px 12px;
        border-radius: 100px;
        margin-bottom: 1rem;
    }

    .info-list {
        list-style: none;
        padding: 0;
        margin: 1.5rem 0;
    }

        .info-list li {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            font-size: 0.9rem;
            color: #475569;
            padding: 8px 0;
            border-bottom: 1px solid #f1f5f9;
            line-height: 1.5;
        }

            .info-list li:last-child {
                border-bottom: none;
            }

            .info-list li span:first-child {
                font-size: 1rem;
                flex-shrink: 0;
                margin-top: 1px;
            }

    .btn-outline-blue {
        display: inline-block;
        border: 2px solid var(--kmc-blue);
        color: var(--kmc-blue);
        border-radius: 8px;
        padding: 10px 24px;
        font-size: 0.875rem;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.2s;
    }

        .btn-outline-blue:hover {
            background: var(--kmc-blue);
            color: white;
        }

    /* ── CTA BAND ── */
    .cta-band {
        background: linear-gradient(135deg, #1e3a8a 0%, #1a56db 60%, #0ea5e9 100%);
        padding: 4rem 0;
        color: white;
        text-align: center;
    }

        .cta-band h2 {
            font-size: clamp(1.6rem, 3vw, 2.3rem);
            font-weight: 800;
            margin-bottom: 0.75rem;
        }

        .cta-band p {
            opacity: 0.8;
            font-size: 0.975rem;
            margin-bottom: 2rem;
        }

    .btn-cta-white {
        background: white;
        color: var(--kmc-blue-dark);
        border: none;
        border-radius: 8px;
        padding: 13px 32px;
        font-size: 0.92rem;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.2s;
        display: inline-block;
    }

        .btn-cta-white:hover {
            background: #dbeafe;
            color: var(--kmc-blue-dark);
            transform: translateY(-1px);
        }

    @@media (max-width: 768px) {
        .hero {
            min-height: 420px;
        }

        .perahera-img-wrap {
            height: 260px;
            margin-bottom: 2rem;
        }

        .stat-item {
            border-right: none;
            border-bottom: 1px solid rgba(255,255,255,0.2);
            padding: 0.8rem 0;
        }
    }
</style>

<!-- HERO -->
<section class="hero">
   
         alt="Kandy Lake" />
    <div class="hero-overlay"></div>
    <div class="container hero-content">
        <div class="row">
            <div class="col-lg-7">
                <div class="hero-eyebrow">Kandy Municipal Council</div>
                <h1>Your City.<br /><span>Your Events.</span></h1>
                <p>
                    Discover, register, and participate in events that bring the
                    community of Kandy together — from cultural celebrations to
                    sports, music and more.
                </p>
                <div class="hero-btns">
                    <a href="/Events" class="btn-hero-primary">Browse Events →</a>
                    <a href="/Register" class="btn-hero-secondary">Create Account</a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- STATS STRIP -->
<div class="stats-strip">
    <div class="container">
        <div class="row text-center">
            <div class="col-6 col-md-3">
                <div class="stat-item">
                    <div class="stat-number">50+</div>
                    <div class="stat-label">Events / Year</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-item">
                    <div class="stat-number">10K+</div>
                    <div class="stat-label">Participants</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-item">
                    <div class="stat-number">8</div>
                    <div class="stat-label">Event Categories</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-item">
                    <div class="stat-number">1</div>
                    <div class="stat-label">City. Kandy 🇱🇰</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- FEATURES -->
<section class="features-section">
    <div class="container">
        <div class="row mb-5">
            <div class="col-12">
                <div class="section-label">Why use this platform</div>
                <h2 class="section-title">Everything you need to stay connected</h2>
                <p class="section-sub">
                    One place for all civic events in Kandy — discover what's happening,
                    register with a click, and never miss a moment.
                </p>
            </div>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">🎪</div>
                    <h4>Discover Events</h4>
                    <p>Browse upcoming cultural, sports, religious and community events across the city with smart filters and search.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">📋</div>
                    <h4>Easy Registration</h4>
                    <p>Register for events in seconds. Track your registrations and get real-time capacity updates before you commit.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">🏛️</div>
                    <h4>Official & Trusted</h4>
                    <p>All events are organised or approved by the Kandy Municipal Council — verified, safe, and community-focused.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- PERAHERA SPOTLIGHT -->
<section class="perahera-section">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <div class="perahera-img-wrap">
                    <img src="/Images/kandy-perahera.jpg"
                         alt="Kandy Esala Perahera" />
                    <div class="perahera-badge">📸 Kandy Esala Perahera</div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="highlight-pill">⭐ Signature Event</div>
                <h2 class="section-title">Kandy Esala Perahera</h2>
                <p style="color:#475569;font-size:0.95rem;line-height:1.75;margin-bottom:0.5rem;">
                    One of Asia's grandest annual processions — a spectacular display of
                    decorated elephants, traditional Kandyan dancers, and fire performers
                    honouring the Sacred Tooth Relic of the Buddha.
                </p>
                <ul class="info-list">
                    <li><span>📅</span><span>Held annually in July / August over ten nights in Kandy</span></li>
                    <li><span>🐘</span><span>Features over 100 decorated elephants and traditional performers</span></li>
                    <li><span>🌍</span><span>Recognised by UNESCO — draws visitors from across the world</span></li>
                    <li><span>🎟️</span><span>Register through this platform for organised viewing spots</span></li>
                </ul>
                <a href="/Events" class="btn-outline-blue">View All Events →</a>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="cta-band">
    <div class="container">
        <h2>Ready to join the community?</h2>
        <p>Create a free account and start registering for events in Kandy today.</p>
        <a href="/Register" class="btn-cta-white">Get Started — It's Free</a>
    </div>
</section>