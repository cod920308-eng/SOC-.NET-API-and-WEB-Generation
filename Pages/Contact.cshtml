@page
@model KMC_Main_WEB.Pages.ContactModel
@{
    ViewData["Title"] = "Contact";
}

<style>
    :root {
        --kmc-blue: #1a56db;
        --kmc-blue-dark: #1e429f;
        --kmc-blue-light: #e8f0fe;
    }

    .contact-hero {
        background: linear-gradient(135deg, #1e429f 0%, #1a56db 60%, #0ea5e9 100%);
        padding: 4rem 0 3rem;
        color: white;
        text-align: center;
    }

        .contact-hero h1 {
            font-size: clamp(2rem, 4vw, 3rem);
            font-weight: 800;
            margin-bottom: 0.5rem;
        }

        .contact-hero p {
            opacity: 0.85;
            font-size: 1rem;
        }

    .contact-section {
        padding: 5rem 0;
    }

        .contact-section.gray {
            background: #f8faff;
        }

    /* IMAGE */
    .contact-img-wrap {
        border-radius: 16px;
        overflow: hidden;
        height: 380px;
    }

        .contact-img-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    /* INFO CARDS */
    .info-card {
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 1.5rem 1.75rem;
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        transition: all 0.2s;
        margin-bottom: 1rem;
    }

        .info-card:hover {
            border-color: #bfdbfe;
            box-shadow: 0 6px 20px rgba(26,86,219,0.08);
        }

    .info-icon {
        width: 44px;
        height: 44px;
        background: var(--kmc-blue-light);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        flex-shrink: 0;
    }

    .info-card h5 {
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #94a3b8;
        margin-bottom: 4px;
    }

    .info-card p {
        font-size: 0.92rem;
        color: #0f172a;
        font-weight: 600;
        margin: 0;
        line-height: 1.6;
    }

    .info-card small {
        font-size: 0.78rem;
        color: #64748b;
        display: block;
        margin-top: 2px;
        font-weight: 400;
    }

    /* HOURS TABLE */
    .hours-table {
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        overflow: hidden;
    }

        .hours-table table {
            width: 100%;
            border-collapse: collapse;
        }

        .hours-table th {
            background: #f8faff;
            padding: 0.75rem 1.25rem;
            font-size: 0.68rem;
            font-weight: 700;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: #64748b;
            border-bottom: 1px solid #e2e8f0;
            text-align: left;
        }

        .hours-table td {
            padding: 0.85rem 1.25rem;
            font-size: 0.875rem;
            color: #1e293b;
            border-bottom: 1px solid #f1f5f9;
        }

        .hours-table tr:last-child td {
            border-bottom: none;
        }

    .open-badge {
        display: inline-block;
        background: #dcfce7;
        color: #16a34a;
        font-size: 0.65rem;
        font-weight: 700;
        padding: 2px 8px;
        border-radius: 100px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
    }

    .closed-badge {
        display: inline-block;
        background: #f1f5f9;
        color: #94a3b8;
        font-size: 0.65rem;
        font-weight: 700;
        padding: 2px 8px;
        border-radius: 100px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
    }

    .section-label {
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--kmc-blue);
        margin-bottom: 8px;
    }

    .section-title {
        font-size: clamp(1.5rem, 3vw, 2.1rem);
        font-weight: 800;
        color: #0f172a;
        line-height: 1.2;
        margin-bottom: 1rem;
    }
</style>

<!-- HERO -->
<div class="contact-hero">
    <div class="container">
        <h1>Contact Us</h1>
        <p>Get in touch with the Kandy Municipal Council</p>
    </div>
</div>

<!-- MAIN CONTACT SECTION -->
<section class="contact-section">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <div class="section-label">Get In Touch</div>
                <h2 class="section-title">We're here to help</h2>
                <p style="color:#475569; font-size:0.95rem; line-height:1.8; margin-bottom:1.75rem;">
                    For enquiries about events, registrations, or general civic matters,
                    reach out to us through any of the channels below. Our team is available
                    during office hours to assist you.
                </p>

                <div class="info-card">
                    <div class="info-icon">📍</div>
                    <div>
                        <h5>Address</h5>
                        <p>Kandy Municipal Council</p>
                        <small>Trinco Rd, Kandy 20000, Sri Lanka</small>
                    </div>
                </div>

                <div class="info-card">
                    <div class="info-icon">📞</div>
                    <div>
                        <h5>Phone</h5>
                        <p>+94 81 222 2222</p>
                        <small>Main line — Mon to Fri, 8:30am – 4:30pm</small>
                    </div>
                </div>

                <div class="info-card">
                    <div class="info-icon">📠</div>
                    <div>
                        <h5>Fax</h5>
                        <p>+94 81 222 4748</p>
                    </div>
                </div>

                <div class="info-card">
                    <div class="info-icon">✉️</div>
                    <div>
                        <h5>Email</h5>
                        <p>info@kandy.mc.gov.lk</p>
                        <small>We typically respond within 2 working days</small>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="contact-img-wrap mb-4">
                    <img src="/Images/lake-view.jpg"
                         alt="Kandy Lake" />
                </div>
            </div>
        </div>
    </div>
</section>

<!-- OFFICE HOURS -->
<section class="contact-section gray">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6 text-center mb-4">
                <div class="section-label">Opening Hours</div>
                <h2 class="section-title">Office Hours</h2>
            </div>
        </div>
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="hours-table">
                    <table>
                        <thead>
                            <tr>
                                <th>Day</th>
                                <th>Hours</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Monday – Friday</td>
                                <td>8:30 AM – 4:30 PM</td>
                                <td><span class="open-badge">Open</span></td>
                            </tr>
                            <tr>
                                <td>Saturday</td>
                                <td>8:30 AM – 1:00 PM</td>
                                <td><span class="open-badge">Open</span></td>
                            </tr>
                            <tr>
                                <td>Sunday</td>
                                <td>—</td>
                                <td><span class="closed-badge">Closed</span></td>
                            </tr>
                            <tr>
                                <td>Public Holidays</td>
                                <td>—</td>
                                <td><span class="closed-badge">Closed</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>