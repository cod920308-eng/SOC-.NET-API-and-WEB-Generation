@page
@model KMC_Main_WEB.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
}

<style>
    .auth-wrap {
        min-height: calc(100vh - 68px);
        display: grid;
        grid-template-columns: 1fr 1fr;
    }

    .auth-left {
        background: linear-gradient(160deg, #1e429f 0%, #1a56db 60%, #0ea5e9 100%);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 5rem 4rem;
        position: relative;
        overflow: hidden;
    }

        .auth-left::before {
            content: 'KMC';
            position: absolute;
            bottom: -3rem;
            left: -1rem;
            font-weight: 700;
            font-size: 18rem;
            color: rgba(255,255,255,0.05);
            line-height: 1;
            pointer-events: none;
        }

    .auth-left-sub {
        font-size: 0.7rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.7);
        margin-bottom: 1rem;
        font-weight: 500;
    }

    .auth-left-title {
        font-size: clamp(2.2rem, 3.5vw, 3.5rem);
        font-weight: 700;
        color: white;
        line-height: 1.1;
        margin-bottom: 1.5rem;
    }

    .auth-left-desc {
        font-size: 0.88rem;
        color: rgba(255,255,255,0.75);
        line-height: 1.8;
        max-width: 340px;
    }

    .auth-left-perks {
        list-style: none;
        margin-top: 2rem;
        padding: 0;
    }

        .auth-left-perks li {
            font-size: 0.84rem;
            color: rgba(255,255,255,0.75);
            padding: 0.6rem 0;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

            .auth-left-perks li::before {
                content: '✦';
                color: rgba(255,255,255,0.5);
                font-size: 0.7rem;
            }

    .auth-left-foot {
        font-size: 0.72rem;
        color: rgba(255,255,255,0.3);
    }

    .auth-right {
        background: #f0f4ff;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 4rem;
    }

    .auth-box {
        width: 100%;
        max-width: 420px;
    }

    .role-pills {
        display: flex;
        gap: 0;
        margin-bottom: 2.5rem;
        border: 1px solid #ddd;
        background: #fff;
        border-radius: 8px;
        overflow: hidden;
    }

    .role-pill {
        flex: 1;
        padding: 0.9rem 1rem;
        text-align: center;
        cursor: pointer;
        background: transparent;
        border: none;
        border-right: 1px solid #ddd;
        transition: background 0.2s;
    }

        .role-pill:last-child {
            border-right: none;
        }

    .role-pill-icon {
        font-size: 1.2rem;
        display: block;
        margin-bottom: 0.3rem;
    }

    .role-pill-label {
        font-size: 0.65rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        font-weight: 600;
        color: #888;
        transition: color 0.2s;
    }

    .role-pill.active {
        background: #1a56db;
    }

        .role-pill.active .role-pill-label {
            color: white;
        }

    .auth-eyebrow {
        font-size: 0.65rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        font-weight: 600;
        color: #1a56db;
        margin-bottom: 0.4rem;
    }

    .auth-title {
        font-weight: 700;
        font-size: clamp(1.8rem, 3vw, 2.4rem);
        color: #0d0d0d;
        margin-bottom: 0.4rem;
    }

    .auth-sub {
        font-size: 0.84rem;
        color: #888;
        margin-bottom: 2rem;
    }

        .auth-sub a {
            color: #1a56db;
            font-weight: 600;
            text-decoration: none;
        }

    .f-group {
        margin-bottom: 1.2rem;
    }

    .f-label {
        display: block;
        font-size: 0.63rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        font-weight: 600;
        color: #666;
        margin-bottom: 0.4rem;
    }

    .f-input {
        width: 100%;
        background: #fff;
        border: 2px solid #e2e8f0;
        padding: 0.85rem 1rem;
        color: #0d0d0d;
        font-size: 0.9rem;
        outline: none;
        transition: border-color 0.2s;
        box-sizing: border-box;
        border-radius: 8px;
    }

        .f-input:focus {
            border-color: #1a56db;
        }

        .f-input::placeholder {
            color: rgba(0,0,0,0.2);
        }

    .f-submit {
        width: 100%;
        background: #1a56db;
        color: white;
        border: none;
        padding: 0.95rem;
        font-size: 0.85rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s;
        margin-top: 0.5rem;
        border-radius: 8px;
    }

        .f-submit:hover {
            background: #1e429f;
        }

    .f-error {
        background: #fff0f0;
        border: 1px solid #fcc;
        color: #c00;
        padding: 0.8rem 1rem;
        font-size: 0.82rem;
        margin-bottom: 1.2rem;
        border-radius: 8px;
    }

    .f-switch {
        text-align: center;
        margin-top: 1.5rem;
        font-size: 0.83rem;
        color: #888;
    }

        .f-switch a {
            color: #1a56db;
            font-weight: 600;
            text-decoration: none;
        }

    @@media (max-width: 768px) {
        .auth-wrap {
            grid-template-columns: 1fr;
        }

        .auth-left {
            display: none;
        }

        .auth-right {
            padding: 2rem 1.5rem;
        }
    }
</style>


<div class="auth-wrap">
    <div class="auth-left">
        <div></div>
        <div>
            <p class="auth-left-sub">KMC Events Platform</p>
            <h2 class="auth-left-title">Kandy's<br>City Events Hub</h2>
            <p class="auth-left-desc">
                Discover, register and participate in events
                happening across the beautiful city of Kandy.
            </p>
            <ul class="auth-left-perks">
                <li>Browse all city events in one place</li>
                <li>Register for events with one click</li>
                <li>Get notified about upcoming events</li>
                <li>Organizers can post events directly</li>
            </ul>
        </div>
        <p class="auth-left-foot">© 2026 Kandy Municipal Council. All rights reserved.</p>
    </div>

    <div class="auth-right">
        <div class="auth-box">
            <div class="role-pills">
                <button class="role-pill active" onclick="setRole('Citizen', this)">
                    <span class="role-pill-icon">👤</span>
                    <span class="role-pill-label">Citizen</span>
                </button>
                <button class="role-pill" onclick="setRole('Organizer', this)">
                    <span class="role-pill-icon">🎪</span>
                    <span class="role-pill-label">Organizer</span>
                </button>
                <button class="role-pill" onclick="setRole('Admin', this)">
                    <span class="role-pill-icon">🔑</span>
                    <span class="role-pill-label">Admin</span>
                </button>
            </div>

            <p class="auth-eyebrow" id="roleEyebrow">Citizen Access</p>
            <h1 class="auth-title">Welcome Back</h1>
            <p class="auth-sub" id="roleSub">
                Login to discover and register for events.
            </p>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="f-error">⚠ @Model.ErrorMessage</div>
            }

            <form method="post">
                <input type="hidden" name="Role" id="roleInput" value="Citizen" />
                <div class="f-group">
                    <label class="f-label">Email Address</label>
                    <input class="f-input" name="Email" type="email"
                           placeholder="your@email.com" required />
                </div>
                <div class="f-group">
                    <label class="f-label">Password</label>
                    <input class="f-input" name="Password" type="password"
                           placeholder="••••••••" required />
                </div>
                <button class="f-submit" type="submit">Sign In →</button>
            </form>

            <div class="f-switch">
                No account? <a href="/Register">Create one here</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const roleData = {
            Citizen: {
                eyebrow: 'Citizen Access',
                sub: 'Login to discover and register for events.'
            },
            Organizer: {
                eyebrow: 'Organizer Access',
                sub: 'Manage and post your events to the KMC platform.'
            },
            Admin: {
                eyebrow: 'Admin Access',
                sub: 'Restricted area — authorized personnel only.'
            }
        };

        function setRole(role, btn) {
            document.querySelectorAll('.role-pill').forEach(p => p.classList.remove('active'));
            btn.classList.add('active');
            document.getElementById('roleInput').value = role;
            document.getElementById('roleEyebrow').textContent = roleData[role].eyebrow;
            document.getElementById('roleSub').textContent = roleData[role].sub;
        }
    </script>


}