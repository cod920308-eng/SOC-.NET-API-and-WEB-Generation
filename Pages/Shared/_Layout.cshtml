<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Kandy Municipal Council</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="icon" href="Images/kmc_logo.png" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
    <style>
        * {
            font-family: 'Inter', sans-serif;
        }

        /* NAVBAR */
        .kmc-nav {
            background: linear-gradient(135deg, #1e429f 0%, #1a56db 100%);
            padding: 0 2rem;
            height: 68px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            box-shadow: 0 2px 16px rgba(26,86,219,0.3);
        }

        .kmc-brand {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }

        .kmc-brand-icon {
            width: 40px;
            height: 40px;
            background: rgba(255,255,255,0.2);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            /* Remove this line ↓ */
            /* backdrop-filter: blur(4px); */
        }

        .kmc-brand-text {
            color: white;
            line-height: 1.1;
        }

            .kmc-brand-text strong {
                display: block;
                font-size: 16px;
                font-weight: 700;
                letter-spacing: 0.02em;
            }

            .kmc-brand-text span {
                font-size: 14px;
				font-weight: bold;
                
                letter-spacing: 0.1em;
                text-transform: uppercase;
            }

        .kmc-nav-links {
            display: flex;
            align-items: center;
            gap: 4px;
            list-style: none;
            margin: 0;
            padding: 0;
        }

            .kmc-nav-links a {
                color: rgba(255,255,255,0.85);
                text-decoration: none;
                font-size: 14px;
                font-weight: 500;
                padding: 8px 14px;
                border-radius: 8px;
                transition: all 0.2s;
            }

                .kmc-nav-links a:hover {
                    background: rgba(255,255,255,0.15);
                    color: white;
                }

                .kmc-nav-links a.active {
                    background: rgba(255,255,255,0.2);
                    color: white;
                }

        .kmc-nav-right {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        /* Show user name when logged in */
        .kmc-user-badge {
            display: flex;
            align-items: center;
            gap: 8px;
            color: rgba(255,255,255,0.9);
            font-size: 14px;
            font-weight: 500;
            background: rgba(255,255,255,0.1);
            padding: 6px 14px;
            border-radius: 100px;
        }

            .kmc-user-badge span {
                font-size: 11px;
                opacity: 0.75;
                text-transform: uppercase;
                letter-spacing: 0.08em;
            }

        .btn-nav-login {
            background: white;
            color: #1a56db;
            border: none;
            border-radius: 8px;
            padding: 8px 20px;
            font-size: 14px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s;
        }

            .btn-nav-login:hover {
                background: #e8f0fe;
                color: #1e429f;
            }

        .btn-nav-logout {
            background: rgba(255,255,255,0.15);
            color: white;
            border: 1px solid rgba(255,255,255,0.3);
            border-radius: 8px;
            padding: 8px 16px;
            font-size: 14px;
            font-weight: 500;
            text-decoration: none;
            transition: all 0.2s;
        }

            .btn-nav-logout:hover {
                background: rgba(255,255,255,0.25);
                color: white;
            }

        /* MAIN CONTENT */
        main {
            margin-top: 68px;
            min-height: calc(100vh - 68px - 200px);
        }

        /* FOOTER */
        .kmc-footer {
            background: linear-gradient(135deg, #1e3a8a 0%, #1e429f 100%);
            color: white;
            padding: 3rem 0 1.5rem;
            margin-top: auto;
        }

        .footer-brand {
            font-size: 20px;
            font-weight: 700;
            margin-bottom: 8px;
			display: flex;
			gap: 12px;
        }
        .footer-brand p{
			margin-top:7px;
        }
        .footer-desc {
            font-size: 13px;
            opacity: 0.7;
            max-width: 280px;
            line-height: 1.6;
        }

        .footer-heading {
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            opacity: 0.6;
            margin-bottom: 12px;
        }

        .footer-links {
            list-style: none;
            padding: 0;
            margin: 0;
        }

            .footer-links li {
                margin-bottom: 8px;
            }

            .footer-links a {
                color: rgba(255,255,255,0.75);
                text-decoration: none;
                font-size: 14px;
                transition: color 0.2s;
            }

                .footer-links a:hover {
                    color: white;
                }

        .footer-divider {
            border-color: rgba(255,255,255,0.15);
            margin: 2rem 0 1rem;
        }

        .footer-bottom {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 13px;
            opacity: 0.6;
        }

        /* Mobile hamburger */
        .kmc-hamburger {
            display: none;
            background: transparent;
            border: none;
            color: white;
            font-size: 24px;
            cursor: pointer;
        }

        @@media (max-width: 768px) {
            .kmc-nav-links {
                display: none;
            }

            .kmc-hamburger {
                display: block;
            }

            .kmc-nav {
                padding: 0 1rem;
            }
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    @{
        var userName = Context.Session.GetString("user_name");
        var userRole = Context.Session.GetString("user_role");
        var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
    }

    <!-- NAVBAR -->
    <nav class="kmc-nav">
        <a href="/" class="kmc-brand">
            <div class="kmc-brand-icon"><img src="Images/kmc_logo.png"  width="50px" height="50px"/></div>
            <div class="kmc-brand-text">
                
                <span>Kandy Municipal Council</span>
            </div>
        </a>

        <ul class="kmc-nav-links">
            <li><a href="/" class="@(currentPage == "/Index" ? "active" : "")">Home</a></li>
            <li><a href="/About" class="@(currentPage == "/About" ? "active" : "")">About</a></li>
            <li><a href="/Events" class="@(currentPage == "/Events" ? "active" : "")">Events</a></li>
            <li><a href="/Contact" class="@(currentPage == "/Contact" ? "active" : "")">Contact</a></li>
        </ul>

        <div class="kmc-nav-right">
            @if (!string.IsNullOrEmpty(userName)){
               if(userRole == "Organizer")
            {
                <a href="/OrganizerDashboard">
                    <div class="kmc-user-badge">
                    👤 @userName
                    <span>(@userRole)</span>
                    </div>
                </a>
                <a href="/Logout" class="btn-nav-logout">Logout</a>
            }
            else if(userRole == "Citizen")
                    {
                        
                           <div class="kmc-user-badge">
                                👤 @userName
                         
                    </div>
                    <a href="/Logout" class="btn-nav-logout">Logout</a>
                    }
                    
            else if (userRole == "Admin")
            {
                <a href="/AdminDashboard">
                <div class="kmc-user-badge">
                    🔑 Admin

                </div>
                </a>
                <a href="/Logout" class="btn-nav-logout">Logout</a>
            }

            }
                 
            else
            {
                <a href="/Login" class="btn-nav-login">Create Account / Login</a>
               
            }
               
        </div>
    </nav>

                                
    <main>
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="kmc-footer">
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-4">

                    <div class="footer-brand"><div class="kmc-brand-icon"><img src="Images/kmc_logo.png" width="50px" height="50px" /></div> <p>Kandy Municipal Council</p></div>
                    <p class="footer-desc">
                        The official event platform of the Kandy Municipal Council.
                        Connecting residents with city events.
                    </p>
                </div>
                <div class="col-md-2 mb-4">
                    <div class="footer-heading">Navigation</div>
                    <ul class="footer-links">
                        <li><a href="/">Home</a></li>
                        <li><a href="/About">About</a></li>
                        <li><a href="/Events">Events</a></li>
                        <li><a href="/Contact">Contact</a></li>
                    </ul>
                </div>
                <div class="col-md-2 mb-4">
                    <div class="footer-heading">Account</div>
                    <ul class="footer-links">
                        <li><a href="/Login">Login</a></li>
                        <li><a href="/Register">Register</a></li>
                    </ul>
                </div>
                <div class="col-md-4 mb-4">
                    <div class="footer-heading">Contact</div>
                    <ul class="footer-links">
                        <li>📍 Kandy Municipal Council</li>
                        <li>📞 +94 81 222 2222</li>
                        <li>✉️ info@kandy.mc.gov.lk</li>
                    </ul>
                </div>
            </div>
            <hr class="footer-divider" />
            <div class="footer-bottom">
                <span>© 2026 Kandy Municipal Council. All rights reserved.</span>
                <span>Built for the people of Kandy 🇱🇰</span>
            </div>
        </div>
    </footer>



    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
