@page
@model PrivateWeb.Pages.AboutModel
@{
    ViewData["Title"] = "About";
}

@section Styles {
    <style>
        .about-hero {
            min-height: calc(100vh - 72px);
            display: grid;
            grid-template-columns: 1fr 1fr;
            overflow: hidden;
        }

        .about-left {
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 80px 64px;
            position: relative;
        }

            .about-left::before {
                content: 'AKPE';
                position: absolute;
                top: 60px;
                left: 64px;
                font-family: 'Playfair Display', serif;
                font-size: 120px;
                color: rgba(201,168,76,0.04);
                font-weight: 700;
                pointer-events: none;
                line-height: 1;
            }

        .about-tag {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(201,168,76,0.1);
            border: 1px solid var(--border);
            color: var(--gold);
            font-size: 12px;
            font-weight: 500;
            letter-spacing: 2px;
            text-transform: uppercase;
            padding: 6px 16px;
            border-radius: 100px;
            width: fit-content;
            margin-bottom: 32px;
        }

        .about-title {
            font-family: 'Playfair Display', serif;
            font-size: clamp(42px, 5vw, 64px);
            line-height: 1.1;
            color: var(--text);
            margin-bottom: 24px;
        }

            .about-title em {
                color: var(--gold);
                font-style: normal;
            }

        .about-desc {
            color: var(--text-muted);
            font-size: 16px;
            line-height: 1.7;
            max-width: 440px;
            margin-bottom: 48px;
        }

        .about-right {
            position: relative;
            overflow: hidden;
        }

        .about-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            filter: brightness(0.75);
        }

        .about-img-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to right, var(--dark) 0%, transparent 40%);
        }

        .about-section {
            padding: 120px 64px;
            background: var(--dark2);
        }

        .about-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 80px;
            align-items: center;
            max-width: 1200px;
            margin: 0 auto;
        }

        .about-text h2 {
            font-family: 'Playfair Display', serif;
            font-size: 42px;
            color: var(--text);
            margin-bottom: 32px;
        }

        .about-text p {
            color: var(--text-muted);
            font-size: 16px;
            line-height: 1.8;
            margin-bottom: 24px;
        }

        .about-image {
            width: 100%;
            height: 480px;
            object-fit: cover;
            border-radius: 16px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.6);
        }
    </style>
}

<section class="about-hero">
	<div class="about-left">
		<div class="about-tag">✦ About Aloka  Public Events Kandy</div>
        <h1 class="about-title">
            Connecting Kandy's<br>
            Community to <em>Events</em>
        </h1>
        <p class="about-desc">
			Aloka  Public Events Kandy is a community-driven platform dedicated
            to bringing the people of Kandy closer to the events that matter —
            cultural, social, educational and more.
        </p>
    </div>

    <div class="about-right">
        <img src="~/images/kandy-lake.jpg"
             alt="Kandy Lake"
             class="about-img"
             onerror="this.style.background='linear-gradient(135deg,#1a1a1a,#252525)'; this.style.display='block'" />
        <div class="about-img-overlay"></div>
    </div>
</section>

<section class="about-section">
    <div class="about-grid">
        <div class="about-text">
            <h2>Our Mission</h2>
            <p>Kandy is the cultural heartbeat of Sri Lanka — a city where tradition, community and celebration come together. Aloka Kandy Public Events was created to make sure no one misses out on the moments that bring this city to life.</p>
            <p>We partner with trusted local organizers to list verified events across Kandy, making it simple for citizens to discover, register and attend events that matter to them.</p>
            <p>Whether it's a religious ceremony near the Temple of the Tooth, a sports day at the city grounds, or a community health camp in your neighborhood — we bring it all to one place.</p>
        </div>

        <img src="~/images/kandy-temple.jpg"
             alt="Temple of the Tooth, Kandy"
             class="about-image"/>
    </div>
</section>