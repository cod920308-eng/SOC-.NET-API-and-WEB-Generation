@page
@model PrivateWeb.Pages.RegisterModel
@{
    ViewData["Title"] = "Register";
}

@section Styles {
    <style>
        .auth-page {
            min-height: calc(100vh - 72px);
            display: grid;
            grid-template-columns: 1fr 1fr;
        }

        .auth-left {
            background: linear-gradient(160deg, #111 0%, #1a1a1a 100%);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 5rem 4rem;
            position: relative;
            overflow: hidden;
            border-right: 1px solid rgba(201,168,76,0.15);
        }

            .auth-left::before {
                content: 'JOIN';
                position: absolute;
                bottom: -3rem;
                left: -1rem;
                font-family: 'Playfair Display', serif;
                font-weight: 700;
                font-size: 14rem;
                color: rgba(201,168,76,0.04);
                line-height: 1;
                pointer-events: none;
            }

        .auth-left-sub {
            font-size: 0.7rem;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--gold);
            margin-bottom: 1rem;
            font-weight: 500;
        }

        .auth-left-title {
            font-family: 'Playfair Display', serif;
            font-size: clamp(2.2rem, 3.5vw, 3.5rem);
            color: var(--text);
            line-height: 1.1;
            margin-bottom: 1.5rem;
        }

        .auth-left-desc {
            font-size: 0.88rem;
            color: var(--text-muted);
            line-height: 1.8;
            max-width: 340px;
        }

        .auth-left-perks {
            list-style: none;
            margin-top: 2rem;
        }

            .auth-left-perks li {
                font-size: 0.84rem;
                color: var(--text-muted);
                padding: 0.6rem 0;
                border-bottom: 1px solid rgba(255,255,255,0.05);
                display: flex;
                align-items: center;
                gap: 0.75rem;
            }

                .auth-left-perks li::before {
                    content: '✦';
                    color: var(--gold);
                    font-size: 0.7rem;
                }

        .auth-left-foot {
            font-size: 0.72rem;
            color: rgba(255,255,255,0.18);
        }

        .auth-right {
            background: #f7f5f0;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 4rem;
        }

        .auth-box {
            width: 100%;
            max-width: 420px;
        }

        .auth-eyebrow {
            font-size: 0.65rem;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            font-weight: 600;
            color: var(--gold);
            margin-bottom: 0.4rem;
        }

        .auth-title {
            font-family: 'Playfair Display', serif;
            font-weight: 700;
            font-size: clamp(1.8rem, 3vw, 2.4rem);
            color: #0d0d0d;
            margin-bottom: 0.4rem;
        }

        .auth-sub {
            font-size: 0.84rem;
            color: #888;
            margin-bottom: 2rem;
        }

            .auth-sub a {
                color: var(--dark);
                font-weight: 600;
                text-decoration: none;
                border-bottom: 1px solid var(--gold);
            }

        .f-group {
            margin-bottom: 1.2rem;
        }

        .f-label {
            display: block;
            font-size: 0.63rem;
            letter-spacing: 0.16em;
            text-transform: uppercase;
            font-weight: 600;
            color: #666;
            margin-bottom: 0.4rem;
        }

        .f-input {
            width: 100%;
            background: #fff;
            border: 1px solid #ddd;
            padding: 0.85rem 1rem;
            color: #0d0d0d;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.9rem;
            outline: none;
            transition: border-color 0.2s;
            box-sizing: border-box;
            border-radius: 4px;
        }

            .f-input:focus {
                border-color: var(--gold);
            }

            .f-input::placeholder {
                color: rgba(0,0,0,0.2);
            }

        .f-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }

        .f-submit {
            width: 100%;
            background: var(--dark);
            color: var(--gold);
            border: none;
            padding: 0.95rem;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.78rem;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.2s;
            margin-top: 0.5rem;
            border-radius: 4px;
        }

            .f-submit:hover {
                background: #222;
            }

        .f-error {
            background: #fff0f0;
            border: 1px solid #fcc;
            color: #c00;
            padding: 0.8rem 1rem;
            font-size: 0.82rem;
            margin-bottom: 1.2rem;
            border-radius: 4px;
        }

        .f-success {
            background: #f0fff4;
            border: 1px solid #b2f5c8;
            color: #276749;
            padding: 0.8rem 1rem;
            font-size: 0.82rem;
            margin-bottom: 1.2rem;
            border-radius: 4px;
        }

        .f-switch {
            text-align: center;
            margin-top: 1.5rem;
            font-size: 0.83rem;
            color: #888;
        }

            .f-switch a {
                color: var(--dark);
                font-weight: 600;
                text-decoration: none;
                border-bottom: 1px solid var(--gold);
            }

        .f-hint {
            font-size: 0.72rem;
            color: #aaa;
            margin-top: 0.3rem;
        }

        @@media (max-width: 768px) {
            .auth-page {
                grid-template-columns: 1fr;
            }

            .auth-left {
                display: none;
            }

            .auth-right {
                padding: 2rem 1.5rem;
            }

            .f-row {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

<div class="auth-page">
    <div class="auth-left">
        <div></div>
        <div>
            <p class="auth-left-sub">Join the Platform</p>
            <h2 class="auth-left-title">Register as<br>a Citizen</h2>
            <p class="auth-left-desc">
                Create your citizen account and start registering for events across Kandy instantly.
            </p>
            <ul class="auth-left-perks">
                <li>Free to register</li>
                <li>Browse events across the city</li>
                <li>Register for events with one click</li>
                <li>Track your registrations easily</li>
            </ul>
        </div>
        <p class="auth-left-foot">© 2026 Kandy Municipal Council. All rights reserved.</p>
    </div>

    <div class="auth-right">
        <div class="auth-box">

            <p class="auth-eyebrow">Citizen Account</p>
            <h1 class="auth-title">Create Account</h1>
            <p class="auth-sub">
                Already registered? <a href="/Login">Sign in here</a>
            </p>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="f-error">⚠ @Model.ErrorMessage</div>
            }
            @if (!string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <div class="f-success">✓ @Model.SuccessMessage</div>
            }

            <form method="post">
                <input type="hidden" name="Role" value="Citizen" />

                <div class="f-group">
                    <label class="f-label">Full Name</label>
                    <input class="f-input" name="FullName" type="text"
                           placeholder="Your full name" required />
                </div>

                <div class="f-group">
                    <label class="f-label">Email Address</label>
                    <input class="f-input" name="Email" type="email"
                           placeholder="your@email.com" required />
                </div>

                <div class="f-group">
                    <label class="f-label">Phone Number</label>
                    <input class="f-input" name="PhoneNumber" type="tel"
                           placeholder="07X XXX XXXX" required />
                </div>

                <div class="f-row">
                    <div class="f-group">
                        <label class="f-label">Password</label>
                        <input class="f-input" name="Password" type="password"
                               placeholder="••••••••" required />
                        <p class="f-hint">Min. 6 characters</p>
                    </div>
                    <div class="f-group">
                        <label class="f-label">Confirm Password</label>
                        <input class="f-input" name="Confirm" type="password"
                               placeholder="••••••••" required />
                    </div>
                </div>

                <button class="f-submit" type="submit">Create Account →</button>
            </form>

            <div class="f-switch">
                Already have an account? <a href="/Login">Sign in</a>
            </div>
        </div>
    </div>
</div>