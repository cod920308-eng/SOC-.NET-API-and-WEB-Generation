@page
@model PrivateWeb.Pages.EventsModel
@{
    ViewData["Title"] = "Events";
}

@section Styles {
    <style>
        .events-page {
            padding: 6rem 4rem 4rem;
            max-width: 1300px;
            margin: 0 auto;
        }

        .events-hero {
            margin-bottom: 3rem;
        }

            .events-hero h1 {
                font-family: 'Playfair Display', serif;
                font-size: clamp(2rem,4vw,3.2rem);
                color: var(--text);
                margin-bottom: 0.5rem;
            }

            .events-hero p {
                color: var(--text-muted);
                font-size: 0.9rem;
            }

        .search-bar {
            display: flex;
            gap: 12px;
            margin-bottom: 1.5rem;
            flex-wrap: wrap;
        }

        .search-input {
            flex: 1;
            min-width: 240px;
            background: #1a1a1a;
            border: 1px solid rgba(201,168,76,0.2);
            color: var(--text);
            padding: 0.75rem 1rem;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.9rem;
            border-radius: 6px;
            outline: none;
            transition: border-color 0.2s;
        }

            .search-input:focus {
                border-color: var(--gold);
            }

            .search-input::placeholder {
                color: var(--text-muted);
            }

        .filter-select {
            background: #1a1a1a;
            border: 1px solid rgba(201,168,76,0.2);
            color: var(--text);
            padding: 0.75rem 1rem;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.85rem;
            border-radius: 6px;
            outline: none;
            cursor: pointer;
            transition: border-color 0.2s;
        }

            .filter-select:focus {
                border-color: var(--gold);
            }

            .filter-select option {
                background: #1a1a1a;
            }

        .clear-btn {
            background: transparent;
            color: var(--text-muted);
            border: 1px solid rgba(255,255,255,0.1);
            padding: 0.75rem 1rem;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.85rem;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.2s;
        }

            .clear-btn:hover {
                border-color: var(--gold);
                color: var(--gold);
            }

        .results-count {
            color: var(--text-muted);
            font-size: 0.83rem;
            margin-bottom: 1.5rem;
        }

            .results-count span {
                color: var(--gold);
                font-weight: 600;
            }

        .no-results {
            grid-column: 1/-1;
            text-align: center;
            padding: 3rem 2rem;
            color: var(--text-muted);
            display: none;
        }

        .events-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 1.5rem;
        }

        .event-card {
            background: #141414;
            border: 1px solid rgba(201,168,76,0.12);
            border-radius: 10px;
            overflow: hidden;
            transition: transform 0.25s, border-color 0.25s, box-shadow 0.25s;
            display: flex;
            flex-direction: column;
        }

            .event-card:hover {
                transform: translateY(-4px);
                border-color: rgba(201,168,76,0.4);
                box-shadow: 0 12px 40px rgba(0,0,0,0.4);
            }

        .event-card-img {
            width: 100%;
            height: 180px;
            object-fit: cover;
            display: block;
            background: #1a1a1a;
        }

        .event-card-img-placeholder {
            width: 100%;
            height: 180px;
            background: linear-gradient(135deg, #1a1a1a 0%, #252525 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
        }

        .event-card-body {
            padding: 1.25rem;
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .event-type-badge {
            display: inline-block;
            background: rgba(201,168,76,0.12);
            color: var(--gold);
            font-size: 0.65rem;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            padding: 3px 10px;
            border-radius: 100px;
            margin-bottom: 0.6rem;
            border: 1px solid rgba(201,168,76,0.2);
        }

        .event-card-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.15rem;
            color: var(--text);
            margin-bottom: 0.75rem;
            line-height: 1.3;
        }

        .event-card-meta {
            display: flex;
            flex-direction: column;
            gap: 6px;
            margin-bottom: 1rem;
        }

        .event-meta-row {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.82rem;
            color: var(--text-muted);
        }

        .event-meta-icon {
            font-size: 0.85rem;
            width: 16px;
            text-align: center;
        }

        .event-card-divider {
            border: none;
            border-top: 1px solid rgba(255,255,255,0.06);
            margin: 0.75rem 0;
        }

        .capacity-row {
            display: flex;
            justify-content: space-between;
            font-size: 0.75rem;
            color: var(--text-muted);
            margin-bottom: 4px;
        }

        .capacity-bar {
            height: 4px;
            background: rgba(255,255,255,0.08);
            border-radius: 100px;
            overflow: hidden;
            margin-bottom: 1rem;
        }

        .capacity-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--gold), var(--gold-light));
            border-radius: 100px;
            transition: width 0.5s ease;
        }

            .capacity-fill.full {
                background: linear-gradient(90deg, #e53e3e, #fc8181);
            }

        .event-card-footer {
            margin-top: auto;
        }

        .register-btn {
            width: 100%;
            background: var(--gold);
            color: var(--dark);
            border: none;
            padding: 0.75rem;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.78rem;
            font-weight: 700;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            border-radius: 6px;
            cursor: pointer;
            transition: background 0.2s;
        }

            .register-btn:hover {
                background: var(--gold-light);
            }

            .register-btn:disabled {
                background: rgba(255,255,255,0.08);
                color: var(--text-muted);
                cursor: not-allowed;
            }

            .register-btn.registered {
                background: rgba(47,133,90,0.2);
                color: #68d391;
                border: 1px solid rgba(47,133,90,0.3);
                cursor: default;
            }

        .login-to-register {
            display: block;
            width: 100%;
            text-align: center;
            background: transparent;
            border: 1px solid rgba(201,168,76,0.3);
            color: var(--gold);
            padding: 0.75rem;
            font-size: 0.78rem;
            font-weight: 600;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            border-radius: 6px;
            text-decoration: none;
            transition: all 0.2s;
        }

            .login-to-register:hover {
                background: rgba(201,168,76,0.08);
            }

        .ended-badge {
            display: block;
            width: 100%;
            text-align: center;
            background: rgba(255,255,255,0.04);
            color: var(--text-muted);
            padding: 0.75rem;
            font-size: 0.75rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            border-radius: 6px;
        }

        .status-dot {
            display: inline-block;
            width: 7px;
            height: 7px;
            border-radius: 50%;
            margin-right: 5px;
        }

        .dot-active {
            background: #68d391;
        }

        .dot-upcoming {
            background: var(--gold);
        }

        .dot-ended {
            background: #666;
        }

        .no-events {
            grid-column: 1/-1;
            text-align: center;
            padding: 5rem 2rem;
            color: var(--text-muted);
        }

            .no-events h3 {
                font-family: 'Playfair Display', serif;
                color: var(--text);
                font-size: 1.4rem;
                margin-bottom: 0.5rem;
            }

        .status-toast {
            text-align: center;
            padding: 0.85rem 1.2rem;
            border-radius: 8px;
            font-size: 0.9rem;
            margin-bottom: 1.5rem;
        }

        .toast-success {
            background: rgba(47,133,90,0.15);
            border: 1px solid rgba(47,133,90,0.3);
            color: #68d391;
        }

        .toast-error {
            background: rgba(229,62,62,0.1);
            border: 1px solid rgba(229,62,62,0.3);
            color: #fc8181;
        }

        @@media (max-width: 768px) {
            .events-page {
                padding: 5rem 1.5rem 3rem;
            }

            .events-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

<div class="events-page">
    <div class="events-hero">
        <h1>Kandy Events</h1>
        <p>Discover and register for events happening across the city</p>
    </div>

    <!-- SEARCH & FILTERS -->
    <div class="search-bar">
        <input type="text" id="searchInput" class="search-input"
               placeholder="Search events..." oninput="filterEvents()" />
        <select id="filterType" class="filter-select" onchange="filterEvents()">
            <option value="">All Types</option>
            @foreach (var t in Model.Events
                        .Where(e => !string.IsNullOrEmpty(e.type))
                        .Select(e => e.type!).Distinct().OrderBy(t => t))
            {
                <option value="@t">@t</option>
            }
        </select>
        <input type="date" id="filterDate" class="filter-select" onchange="filterEvents()" />
        <select id="filterStatus" class="filter-select" onchange="filterEvents()">
            <option value="">All Status</option>
            <option value="upcoming">Upcoming</option>
            <option value="active">Active</option>
            <option value="ended">Ended</option>
        </select>
        <button class="clear-btn" onclick="clearFilters()">Clear</button>
    </div>

    <!-- SERVER-SIDE TOAST -->
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="status-toast @(Model.IsSuccess ? "toast-success" : "toast-error")">
            @Model.StatusMessage
        </div>
    }

    <p class="results-count" id="resultsCount">
        Showing <span>@Model.Events.Count</span> event@(Model.Events.Count != 1 ? "s" : "")
    </p>

    <div class="no-results" id="noResults">
        <h3>No Events Found</h3>
        <p>Try adjusting your filters.</p>
    </div>

    @if (Model.Events.Any())
    {
        <div class="events-grid" id="eventsGrid">
            @foreach (var ev in Model.Events)
            {
                var now = DateTime.Now;
                var status = now < ev.startDate ? "upcoming"
                : now > ev.endDate ? "ended"
                : "active";
                var pct = ev.capacity > 0
                ? Math.Min(100, (int)Math.Round((double)ev.currentParticipants / ev.capacity * 100))
                : 0;
                var isFull = ev.currentParticipants >= ev.capacity;
                var isEnded = status == "ended";
                var registered = Model.RegisteredEventIds.Contains(ev.id);
                var statusDot = status switch
                {
                    "active" => "<span class=\"status-dot dot-active\"></span>Active",
                    "upcoming" => "<span class=\"status-dot dot-upcoming\"></span>Upcoming",
                    _ => "<span class=\"status-dot dot-ended\"></span>Ended"
                };

                <div class="event-card"
                     data-title="@ev.title?.ToLower()"
                     data-type="@ev.type?.ToLower()"
                     data-date="@ev.startDate.ToString("yyyy-MM-dd")"
                     data-status="@status">

                    @if (!string.IsNullOrEmpty(ev.eventImage))
                    {
                        <img class="event-card-img"
                             src="https://localhost:7096/@ev.eventImage.TrimStart('/')"
                             alt="@ev.title"
                             onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                        <div class="event-card-img-placeholder" style="display:none">🎪</div>
                    }
                    else
                    {
                        <div class="event-card-img-placeholder">🎪</div>
                    }

                    <div class="event-card-body">
                        <span class="event-type-badge">@(ev.type ?? "General")</span>
                        <h3 class="event-card-title">@ev.title</h3>

                        <div class="event-card-meta">
                            <div class="event-meta-row">
                                <span class="event-meta-icon">📅</span>
                                @ev.startDate.ToString("dd MMM yyyy")
                                @if (ev.endDate != ev.startDate)
                                {
                                    <span>— @ev.endDate.ToString("dd MMM yyyy")</span>
                                }
                            </div>
                            <div class="event-meta-row">
                                <span class="event-meta-icon">🕐</span>
                                @ev.startDate.ToString("hh:mm tt")
                                @if (ev.endDate != ev.startDate)
                                {
                                    <span>— @ev.endDate.ToString("hh:mm tt")</span>
                                }
                            </div>
                            <div class="event-meta-row">
                                <span class="event-meta-icon">📍</span>
                                @(ev.location ?? "Kandy, Sri Lanka")
                            </div>
                            @if (ev.organizer != null)
                            {
                                <div class="event-meta-row">
                                    <span class="event-meta-icon">🏢</span>
                                    <span style="font-weight:500;color:#c9a84c;">
                                        @(ev.organizer.organizationName ?? ev.organizer.fullName ?? "—")
                                    </span>
                                </div>
                                <div class="event-meta-row">
                                    <span class="event-meta-icon">👤</span>
                                    @(ev.organizer.fullName ?? "—")
                                </div>
                            }
                            <div class="event-meta-row">
                                <span class="event-meta-icon">🔵</span>
                                @Html.Raw(statusDot)
                            </div>
                        </div>

                        <hr class="event-card-divider" />

                        <div class="capacity-row">
                            <span>Capacity</span>
                            <span>@ev.currentParticipants / @ev.capacity</span>
                        </div>
                        <div class="capacity-bar">
                            <div class="capacity-fill @(isFull ? "full" : "")"
                                 style="width:@pct%"></div>
                        </div>

                        <div class="event-card-footer">
                            @if (isEnded)
                            {
                                <span class="ended-badge">Event Ended</span>
                            }
                            else if (Model.UserRole == "Organizer" || Model.UserRole == "Admin")
                            {
                                <button class="register-btn" disabled style="opacity:.4">Organizer View</button>
                            }
                            else if (registered)
                            {
                                <button class="register-btn registered" disabled>✓ Registered</button>
                            }
                            else if (isFull)
                            {
                                <button class="register-btn" disabled>Full</button>
                            }
                            else if (Model.UserRole == "Citizen")
                            {
                                <form method="post" asp-page-handler="Register">
                                    <input type="hidden" name="eventId" value="@ev.id" />
                                    <button type="submit" class="register-btn">Register →</button>
                                </form>
                            }
                            else
                            {
                                <a href="/Login" class="login-to-register">Login to Register</a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="events-grid">
            <div class="no-events">
                <h3>No Events Found</h3>
                <p>Make sure the API is running.</p>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        function filterEvents() {
            const q      = document.getElementById('searchInput').value.toLowerCase();
            const type   = document.getElementById('filterType').value.toLowerCase();
            const date   = document.getElementById('filterDate').value;
            const status = document.getElementById('filterStatus').value;

            const cards = document.querySelectorAll('#eventsGrid .event-card');
            let visible = 0;

            cards.forEach(card => {
                const matchQ      = !q      || (card.dataset.title || '').includes(q);
                const matchType   = !type   || card.dataset.type === type;
                const matchDate   = !date   || card.dataset.date === date;
                const matchStatus = !status || card.dataset.status === status;
                const show = matchQ && matchType && matchDate && matchStatus;
                card.style.display = show ? '' : 'none';
                if (show) visible++;
            });

            const total = cards.length;
            document.getElementById('resultsCount').innerHTML =
                (q || type || date || status)
                ? `Showing <span>${visible}</span> of <span>${total}</span> events`
                : `Showing <span>${total}</span> event${total !== 1 ? 's' : ''}`;

            document.getElementById('noResults').style.display =
                visible === 0 ? 'block' : 'none';
        }

        function clearFilters() {
            document.getElementById('searchInput').value  = '';
            document.getElementById('filterType').value   = '';
            document.getElementById('filterDate').value   = '';
            document.getElementById('filterStatus').value = '';
            filterEvents();
        }


    </script>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <script>
            alert('@Model.StatusMessage');
        </script>
    }
}