@page
@model PrivateWeb.Pages.ContactModel
@{
    ViewData["Title"] = "Contact";
}

@section Styles {
    <style>
        .contact-hero {
            min-height: calc(100vh - 72px);
            background: linear-gradient(rgba(13,13,13,0.8), rgba(13,13,13,0.8)), url('~/images/kandy-lake.jpg') center/cover no-repeat;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 0 64px;
        }

            .contact-hero h1 {
                font-family: 'Playfair Display', serif;
                font-size: clamp(48px, 6vw, 68px);
                color: var(--text);
                margin-bottom: 16px;
            }

            .contact-hero p {
                font-size: 18px;
                color: var(--text-muted);
                max-width: 600px;
                margin: 0 auto;
            }

        .contact-content {
            padding: 120px 64px;
            background: var(--dark2);
        }

        .contact-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 100px;
            max-width: 1100px;
            margin: 0 800px;
			text-align: center;
        }

        .contact-info h3 {
            font-family: 'Playfair Display', serif;
            font-size: 28px;
            color: var(--gold);
            margin-bottom: 32px;
        }

        .info-item {
            display: flex;
            gap: 20px;
            margin-bottom: 40px;
        }

        .info-icon {
            font-size: 28px;
            color: var(--gold);
            width: 50px;
        }

        .info-text h4 {
            color: var(--text);
            margin-bottom: 6px;
        }

        .info-text p {
            color: var(--text-muted);
            font-size: 15px;
        }

        form {
            background: var(--dark3);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 48px;
        }

        input, textarea {
            width: 100%;
            background: var(--dark);
            border: 1px solid var(--border);
            color: var(--text);
            padding: 16px 20px;
            border-radius: 8px;
            margin-bottom: 24px;
            font-size: 15px;
        }

        textarea {
            min-height: 160px;
            resize: vertical;
        }

        button {
            background: var(--gold);
            color: var(--dark);
            border: none;
            padding: 16px 40px;
            border-radius: 8px;
            font-weight: 500;
            font-size: 16px;
            cursor: pointer;
            transition: all 0.2s;
        }

            button:hover {
                background: var(--gold-light);
                transform: translateY(-2px);
            }
    </style>
}


<section class="contact-hero">
    <div>
        <div class="hero-tag" style="margin: 0 auto 24px; width: fit-content;">✦ Get In Touch</div>
        <h1>Let's Make Your Next Event Unforgettable</h1>
        <p>Have questions? Need support? Our team is here to help you organize amazing events in Kandy.</p>
    </div>
</section>


<section class="contact-content">
    <div class="contact-grid">
       
        <div class="contact-info">
            <h3>Contact Information</h3>

            <div class="info-item">
                <div class="info-icon">📍</div>
                <div class="info-text">
                    <h4>Kandy Municipal Council</h4>
                    <p>Deva Veediya,<br>Kandy, Sri Lanka</p>
                </div>
            </div>

            <div class="info-item">
                <div class="info-icon">📞</div>
                <div class="info-text">
                    <h4>Phone</h4>
                    <p>+94 81 222 2266<br>+94 81 223 4567 (Organizer Support)</p>
                </div>
            </div>

            <div class="info-item">
                <div class="info-icon">✉️</div>
                <div class="info-text">
                    <h4>Email</h4>
                    <p>organizers@kandyevents.lk<br>info@kandy.mc.gov.lk</p>
                </div>
            </div>

            <div class="info-item">
                <div class="info-icon">🕒</div>
                <div class="info-text">
                    <h4>Office Hours</h4>
                    <p>Monday – Friday: 8:30 AM – 4:30 PM<br>Saturday: 8:30 AM – 12:00 PM</p>
                </div>
            </div>
        </div>

       
   
    </div>
</section>